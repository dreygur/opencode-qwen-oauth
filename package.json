{
  "name": "opencode-qwen-oauth",
  "version": "2.4.1",
  "description": "OAuth 2.0 Device Flow plugin for OpenCode - authenticate with Qwen.ai (PKCE secured, auto token refresh)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-qwen-oauth": "bin/install.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build",
    "test": "tsx --test tests/**/*.test.ts",
    "test:watch": "tsx --test --watch tests/**/*.test.ts",
    "diagnose": "npm run build && node dist/diagnostic.js",
    "test:tokens": "npm run build && node dist/token-test.js"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "qwen",
    "qwen-ai",
    "oauth",
    "oauth2",
    "device-flow",
    "pkce",
    "authentication",
    "auth",
    "ai",
    "llm",
    "typescript",
    "plugin",
    "ai-auth",
    "headless-auth"
  ],
  "author": "Rakibul Yeasin <ryeasin03@gmail.com>",
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/dreygur"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dreygur/opencode-qwen-oauth.git"
  },
  "bugs": {
    "url": "https://github.com/dreygur/opencode-qwen-oauth/issues"
  },
  "homepage": "https://github.com/dreygur/opencode-qwen-oauth#readme",
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.15"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@ai-sdk/openai-compatible": "^0.0.1"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai-compatible": {
      "optional": true
    }
  }
}
