{
  "name": "opencode-qwen-oauth",
  "version": "2.2.0",
  "description": "Qwen OAuth authentication plugin for OpenCode - authenticate with Qwen.ai using OAuth device flow",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-qwen-oauth": "bin/install.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "diagnose": "npm run build && node dist/diagnostic.js",
    "test:tokens": "npm run build && node dist/token-test.js"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "qwen",
    "oauth",
    "authentication",
    "ai",
    "llm"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/opencode-qwen-oauth.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/opencode-qwen-oauth/issues"
  },
  "homepage": "https://github.com/yourusername/opencode-qwen-oauth#readme",
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.15"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@ai-sdk/openai-compatible": "^0.0.1"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai-compatible": {
      "optional": true
    }
  }
}
